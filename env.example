# Copia este ficheiro para `.env.local` (na raiz do projeto) e preenche
# com os valores de: Supabase Dashboard -> Project Settings -> API.
# O .env.local nunca vai para o git (.gitignore trata disso).

VITE_SUPABASE_URL=https://O-TEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ-a-tua-chave-anon-aqui

# Opcional — notificações push (Web Push). Chave PÚBLICA VAPID.
# Gera com: npx web-push generate-vapid-keys  (a privada vai para os
# secrets da Edge Function, ver supabase/PUSH-SETUP.md)
# VITE_VAPID_PUBLIC_KEY=
